{
  "name": "instant-mock-api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend Development Studio — turn API requirements into a complete backend toolkit in under 3 minutes",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint && pnpm depcruise",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "depcruise": "depcruise --config .dependency-cruiser.cjs apps packages"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.1",
    "dependency-cruiser": "^18.0.0",
    "turbo": "^2.10.4"
  }
}
